worker_processes  auto;

worker_rlimit_nofile 602400;
events {
    worker_connections  10240;
}


http {
    include       mime.types;
    default_type  application/octet-stream;
    access_log off;
    client_body_buffer_size  5m;
    client_max_body_size 100m;
    client_header_buffer_size 4k;
    large_client_header_buffers 4 16k;
    sendfile        on;
    tcp_nopush      on;
    tcp_nodelay     on;
    resolver {{.ResolverIPs}} ipv6=off;
    keepalive_timeout  65;
    lua_ssl_trusted_certificate  /etc/ssl/certs/ca-certificates.crt;
    lua_ssl_verify_depth 3;
    lua_max_running_timers 10240;
    lua_max_pending_timers 10240;
    lua_shared_dict waf_conf_data {{.WafConfData}};
    lua_shared_dict jxwaf_inner {{.JxwafInner}};
    lua_shared_dict jxwaf_user {{.JxwafUser}};
    lua_shared_dict ip_access_limit_stat {{.JxwafRequestCount}};
    lua_shared_dict ip_access_limit_block {{.JxwafRequestCount}};
    lua_shared_dict ip_count_limit_log {{.JxwafRequestIp}};
    lua_shared_dict ip_count_limit_stat {{.JxwafRequestIp}};
    lua_shared_dict domain_access_limit_stat {{.JxwafRequestIpCount}};
    lua_shared_dict jxwaf_limit_bot {{.JxwafLimitBot}};
    lua_shared_dict ssl_attack_stat {{.SslAttackStat}};
    lua_shared_dict ssl_black_ip {{.SslBlackIp}};
    init_by_lua_file /opt/jxwaf/lualib/resty/jxwaf/init.lua;
    init_worker_by_lua_file /opt/jxwaf/lualib/resty/jxwaf/init_worker.lua;
    rewrite_by_lua_file /opt/jxwaf/lualib/resty/jxwaf/rewrite.lua;
    access_by_lua_file /opt/jxwaf/lualib/resty/jxwaf/access.lua;
    body_filter_by_lua_file /opt/jxwaf/lualib/resty/jxwaf/body_filter.lua;
    log_by_lua_file /opt/jxwaf/lualib/resty/jxwaf/log.lua;
    rewrite_by_lua_no_postpone on;
    lua_socket_pool_size 1000;
    upstream jxwaf {
        server www.jxwaf.com;
        balancer_by_lua_file /opt/jxwaf/lualib/resty/jxwaf/balancer.lua;
        keepalive 100;
        keepalive_timeout 60s;
        keepalive_requests 1000;
    }
    lua_code_cache on;
    lua_need_request_body on;
    gzip on;
    gzip_types text/plain text/css application/json application/javascript text/xml application/xml application/xml+rss text/javascript application/font-woff application/font-woff2;
    gzip_vary on;
    gzip_min_length 1024;
    gzip_proxied any;
    server_tokens off;
    map $proxy_pass_https_flag $backend_protocol {
        "true"  "https";
        default "http";
    }
    map $http_upgrade $connection_upgrade {
        default "";
        websocket "upgrade";
    }
    server {
        {{range .HTTPPorts}}
        listen       {{.}};
        {{end}}
        server_name  localhost;
        set $proxy_pass_https_flag "false";
        location / {
            proxy_pass $backend_protocol://jxwaf;
            proxy_ssl_server_name on;
            proxy_ssl_name $http_host;
            proxy_set_header Host  $http_host;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection $connection_upgrade;
            proxy_http_version 1.1;
            proxy_set_header Accept-Encoding "";
        }
    }

    server {
        {{range .HTTPSPorts}}
        listen       {{.}} ssl;
        {{end}}
        server_name  localhost;
        set $proxy_pass_https_flag "false";
        http2 on;
        ssl_certificate      full_chain.pem;
        ssl_certificate_key  private.key;

        ssl_session_cache    shared:SSL:100m;
        ssl_session_timeout  5m;
        ssl_session_tickets on;
        ssl_protocols TLSv1 TLSv1.1 TLSv1.2 TLSv1.3;
        ssl_ciphers 'ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-RSA-CHACHA20-POLY1305:ECDHE-RSA-AES128-SHA256:ECDHE-RSA-AES256-SHA384:ECDHE-RSA-AES128-SHA:ECDHE-RSA-AES256-SHA:AES128-GCM-SHA256:AES256-GCM-SHA384:AES128-SHA256:AES256-SHA256:AES128-SHA:AES256-SHA';
        ssl_prefer_server_ciphers on;
        ssl_certificate_by_lua_file /opt/jxwaf/lualib/resty/jxwaf/ssl.lua;
        ssl_client_hello_by_lua_file /opt/jxwaf/lualib/resty/jxwaf/ssl_client_hello.lua;

        location / {
            proxy_pass $backend_protocol://jxwaf;
            proxy_ssl_server_name on;
            proxy_ssl_name $http_host;
            proxy_ssl_session_reuse on;
            proxy_set_header Host  $http_host;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection $connection_upgrade;
            proxy_set_header Accept-Encoding "";
            proxy_http_version 1.1;
        }
    }
}